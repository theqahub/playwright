{
  "name": "playwright-docs-es",
  "version": "1.0.0",
  "private": true,
  "description": "Laboratorio educativo en espanol para la serie de Playwright",
  "type": "commonjs",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:projects": "FULL_MATRIX=1 playwright test",
    "test:shard:1": "playwright test --shard=1/2",
    "test:shard:2": "playwright test --shard=2/2",
    "pw:codegen": "playwright codegen http://127.0.0.1:3100"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.6.2",
    "typescript": "^5.9.3"
  }
}
